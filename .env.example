DATABASE_URL=sqlite:////data/app.db
BACKEND_PORT=8000
FRONTEND_PORT=4200

# GitLab integration
GITLAB_URL=https://your-gitlab-instance
GITLAB_TOKEN=your-private-token

# Set to false only for self-signed certificates in local/dev environments.
# Never use false in production — it disables SSL certificate verification.
GITLAB_SSL_VERIFY=true
