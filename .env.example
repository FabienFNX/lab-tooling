DATABASE_URL=sqlite:////data/app.db
BACKEND_PORT=8000
FRONTEND_PORT=4200

# GitLab integration
GITLAB_URL=https://your-gitlab-instance
GITLAB_TOKEN=your-private-token

# Set to false only for self-signed certificates in local/dev environments.
# Never use false in production — it disables SSL certificate verification.
GITLAB_SSL_VERIFY=true

# OpenAI — required for transcription (Whisper) and meeting summary (GPT)
OPENAI_API_KEY=sk-...

# Notion — optional, only needed to push summaries to Notion pages
NOTION_API_KEY=secret_...

# Directory where recording session folders are stored (default: data/recordings)
# RECORDINGS_DIR=data/recordings
