{
  "name": "backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/backend",
  "tags": [],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
        "cwd": "apps/backend"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pip install -r requirements.txt",
        "cwd": "apps/backend"
      }
    },
    "init-db": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python -c \"from app.db.init_db import init_db; init_db(); print('DB initialized')\"",
        "cwd": "apps/backend"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python -m flake8 app/",
        "cwd": "apps/backend"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python -m pytest",
        "cwd": "apps/backend"
      }
    }
  }
}
